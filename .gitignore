# Credenciales y configuración local (nunca subir)
.env
*.env.local
config.local.*

# R: objetos y sesión
.RData
.Rhistory
.Rapp.history
.Rproj.user/
*.Rproj
.Ruserdata/

# R: paquetes instalados en el proyecto (si usas renv)
renv/library/

# Archivos generados o temporales
*.rds
*.rda
*.log
*.tmp
*~

# Datos grandes (ya cargados en PostgreSQL)
*.parquet
*.udpipe

# Scripts experimentales / no parte del pipeline
experimental/

# Base de datos: dumps, copias y scripts de uso local
*.dump
*.backup
*.sql.backup
vaciar_db.sql

# Sistema operativo
.DS_Store
Thumbs.db

# IDE / editores
.idea/
*.swp
*.swo

# Scripts de scraping por fuente (se ignoran todos salvo el ejemplo CNN)
scraping/fuentes/scraping_*.r
scraping/fuentes/scraping_*.R
!scraping/fuentes/scraping_cnnchile.r
!scraping/fuentes/scraping_ejemplo.R
